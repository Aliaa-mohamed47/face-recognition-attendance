   ],
   "source": [
    "# Reload and inspect the saved database\n",
    "with open(output_file, \"rb\") as f:\n",
    "    db = pickle.load(f)\n",
    "\n",
    "first_subject = list(db.keys())[0]\n",
    "first_desc    = db[first_subject][0]\n",
    "\n",
    "print(\"Database verification\")\n",

   "source": [
    "import os\n",
    "import cv2\n",
    "import pickle\n",
    "import kagglehub\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "print(\"All libraries imported successfully.\")\n",
    "print(f\"OpenCV version: {cv2.__version__}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step3-header",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 3 — Download the Dataset\n",
    "\n",
    "We use `kagglehub` to automatically download the AT&T face dataset.  \n",
    "No API key or manual download is required."
   ]
  },
  {
   "cell_type": "code",
   "id": "download-cell",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Extracting files...\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Dataset downloaded successfully.\n",
     ]
    }
   ],
   "source": [
    "# Download the AT&T Faces dataset from Kaggle\n",
    "dataset_path = kagglehub.dataset_download(\"kasikrit/att-database-of-faces\")\n",
    "\n",
    "print(\"Dataset downloaded successfully.\")\n",
    "print(f\"Path: {dataset_path}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step4-header",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 4 — Explore the Dataset Structure"
   ]
  },
  {
   "cell_type": "code",
   "id": "explore-cell",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total subjects found : 40\n",
      "Subject folders      : ['s1', 's10', 's11', 's12', 's13'] ... ['s7', 's8', 's9']\n",
      "Images per subject   : 10 (example from 's1')\n"
     ]
    }
   ],
   "source": [
    "# List all subject folders in the dataset\n",
    "subjects = sorted(\n",
    "    [f for f in os.listdir(dataset_path) if os.path.isdir(os.path.join(dataset_path, f))]\n",
    ")\n",
    "\n",
    "print(f\"Total subjects found : {len(subjects)}\")\n",
    "print(f\"Subject folders      : {subjects[:5]} ... {subjects[-3:]}\")\n",
    "\n",
    "# Show number of images per subject (as a sanity check)\n",
    "sample_subject = subjects[0]\n",
    "sample_images = os.listdir(os.path.join(dataset_path, sample_subject))\n",
    "print(f\"Images per subject   : {len(sample_images)} (example from '{sample_subject}')\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step5-header",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 5 — Visualize Sample Images\n",
    "\n",
    "We display a few sample images to confirm the dataset is loaded correctly before processing."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "visualize-cell",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<Figure size 1200x500 with 10 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Image size: 112 × 92 pixels\n"
     ]
    }
   ],
   "source": [
    "fig, axes = plt.subplots(2, 5, figsize=(12, 5))\n",
    "fig.suptitle(\"Sample Face Images from AT&T Dataset\", fontsize=13)\n",
    "\n",
    "for i, subject in enumerate(subjects[:10]):\n",
    "    img_path = os.path.join(dataset_path, subject, \"1.pgm\")\n",
    "    img = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)\n",
    "    ax = axes[i // 5][i % 5]\n",
    "    ax.imshow(img, cmap=\"gray\")\n",
    "    ax.set_title(subject, fontsize=9)\n",
    "    ax.axis(\"off\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"Image size: {img.shape[0]} × {img.shape[1]} pixels\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step6-header",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 6 — Initialize SIFT Detector\n",
    "\n",
    "**SIFT (Scale-Invariant Feature Transform)** detects and describes local features in images.  \n",
    "It is robust to changes in scale, rotation, and illumination — ideal for face recognition tasks."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "sift-init-cell",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "SIFT detector initialized.\n",
      "Each image will be described by a set of 128-dimensional keypoint descriptors.\n"
     ]
    }
   ],
   "source": [
    "sift = cv2.SIFT_create()\n",
    "\n",
    "print(\"SIFT detector initialized.\")\n",
    "print(\"Each image will be described by a set of 128-dimensional keypoint descriptors.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step7-header",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 7 — Visualize SIFT Keypoints on a Sample Image\n",
    "\n",
    "Before running full extraction, we visualize the keypoints detected on one image."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "keypoints-cell",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<Figure size 1000x400 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Keypoints detected  : 56\n",
      "Descriptor shape    : (56, 128)  → (56 keypoints × 128 dimensions)\n"
     ]
    }
   ],
   "source": [
    "sample_path = os.path.join(dataset_path, \"s1\", \"1.pgm\")\n",
    "sample_img  = cv2.imread(sample_path, cv2.IMREAD_GRAYSCALE)\n",
    "\n",
    "# Detect keypoints\n",
    "keypoints, descriptors = sift.detectAndCompute(sample_img, None)\n",
    "\n",
    "# Draw keypoints on the image\n",
    "img_with_kp = cv2.drawKeypoints(\n",
    "    sample_img, keypoints, None,\n",
    "    flags=cv2.DRAW_MATCHES_FLAGS_DRAW_RICH_KEYPOINTS\n",
    ")\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(10, 4))\n",
    "axes[0].imshow(sample_img, cmap=\"gray\")\n",
    "axes[0].set_title(\"Original Image\")\n",
    "axes[0].axis(\"off\")\n",
    "\n",
    "axes[1].imshow(img_with_kp)\n",
    "axes[1].set_title(f\"SIFT Keypoints ({len(keypoints)} detected)\")\n",
    "axes[1].axis(\"off\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"Keypoints detected  : {len(keypoints)}\")\n",
    "print(f\"Descriptor shape    : {descriptors.shape}  → ({len(keypoints)} keypoints × 128 dimensions)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step8-header",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 8 — Extract SIFT Features for All Images\n",
    "\n",
    "We iterate over every subject and every image, extract SIFT descriptors, and store them in a dictionary.\n",
    "\n",
    "**Structure of `feature_database`:**\n",
    "```\n",
    "{\n",
    "  \"s1\": [array(n1×128), array(n2×128), ...],   # one array per image\n",
    "  \"s2\": [...],\n",
    "  ...\n",
    "  \"s40\": [...]\n",
    "}\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "extraction-cell",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "s1: 10 images processed\n",
      "s10: 10 images processed\n",
      "s11: 10 images processed\n",
      "s12: 10 images processed\n",
      "s13: 10 images processed\n",
      "s14: 10 images processed\n",
      "s15: 10 images processed\n",
      "s16: 10 images processed\n",
      "s17: 10 images processed\n",
      "s18: 10 images processed\n",
      "s19: 10 images processed\n",
      "s2: 10 images processed\n",
      "s20: 10 images processed\n",
      "s21: 10 images processed\n",
      "s22: 10 images processed\n",
      "s23: 10 images processed\n",
      "s24: 10 images processed\n",
      "s25: 10 images processed\n",
      "s26: 10 images processed\n",
      "s27: 10 images processed\n",
      "s28: 10 images processed\n",
      "s29: 10 images processed\n",
      "s3: 10 images processed\n",
      "s30: 10 images processed\n",
      "s31: 10 images processed\n",
      "s32: 10 images processed\n",
      "s33: 10 images processed\n",
      "s34: 10 images processed\n",
      "s35: 10 images processed\n",
      "s36: 10 images processed\n",
      "s37: 10 images processed\n",
      "s38: 10 images processed\n",
      "s39: 10 images processed\n",
      "s4: 10 images processed\n",
      "s40: 10 images processed\n",
      "s5: 10 images processed\n",
      "s6: 10 images processed\n",
      "s7: 10 images processed\n",
      "s8: 10 images processed\n",
      "s9: 10 images processed\n",
      "\n",
      "Extraction complete.\n",
      "Total subjects      : 40\n",
      "Skipped images      : 0\n"
     ]
    }
   ],
   "source": [
    "feature_database = {}\n",
    "skipped_images   = 0\n",
    "\n",
    "for subject in subjects:\n",
    "    subject_path     = os.path.join(dataset_path, subject)\n",
    "    descriptors_list = []\n",
    "\n",
    "    for image_name in sorted(os.listdir(subject_path)):\n",
    "        image_path  = os.path.join(subject_path, image_name)\n",
    "        image       = cv2.imread(image_path, cv2.IMREAD_GRAYSCALE)\n",
    "\n",
    "        if image is None:\n",
    "            skipped_images += 1\n",
    "            continue\n",
    "\n",
    "        keypoints, descriptors = sift.detectAndCompute(image, None)\n",
    "\n",
    "        if descriptors is not None:\n",
    "            descriptors_list.append(descriptors)\n",
    "        else:\n",
    "            # No keypoints found — skip this image\n",
    "            skipped_images += 1\n",
    "\n",
    "    feature_database[subject] = descriptors_list\n",
    "    print(f\"{subject}: {len(descriptors_list)} images processed\")\n",
    "\n",
    "print(f\"\\nExtraction complete.\")\n",
    "print(f\"Total subjects      : {len(feature_database)}\")\n",
    "print(f\"Skipped images      : {skipped_images}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step9-header",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 9 — Save Feature Database to Disk\n",
    "\n",
    "We serialize the database using Python's `pickle` module.  \n",
    "This preserves NumPy arrays and is efficient for academic experiments.\n",
    "\n",
    "The saved file (`sift_feature_database.pkl`) is the **official output of Module 4**  \n",
    "and will be used directly by the next module for matching and classification."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "save-cell",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Feature database saved : sift_feature_database.pkl\n",
      "File size              : 13606.7 KB\n"
     ]
    }
   ],
   "source": [
    "output_file = \"sift_feature_database.pkl\"\n",
    "\n",
    "with open(output_file, \"wb\") as f:\n",
    "    pickle.dump(feature_database, f)\n",
    "\n",
    "file_size_kb = os.path.getsize(output_file) / 1024\n",
    "\n",
    "print(f\"Feature database saved : {output_file}\")\n",
    "print(f\"File size              : {file_size_kb:.1f} KB\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step10-header",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 10 — Verify Saved Database"
   ]
  },
